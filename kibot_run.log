DEBUG:YAML after expanding definitions:
# KiBot output for generating Bill of Materials in CSV format
# https://kibot.readthedocs.io/en/latest/configuration/outputs/bom.html

kibot:
  version: 1

outputs:
- name: csv_bom
  comment: 'Bill of Materials in CSV format'
  type: bom
  category: 'Manufacturing/Assembly'
  dir: 'Manufacturing/Assembly'
  options:
    format: CSV
    csv:
      hide_pcb_info: true
      hide_stats_info: true
      
    group_fields: ['MPN', 'Value']

    columns:
      - "Row"
      - "Quantity Per PCB"
      - "References"
      - "Value"
      - "Datasheet"
      - "Footprint"
      - "Description"
      - "Tolerance"
      - "Voltage"
      - "Manufacturer"
      - "MPN"
      - "Supplier"
      - "SPN"
      # - "arrow#"
      # - "digikey#"
      # - "farnell#"
      # - "mouser#"
      # - "newark#"
      # - "rs#"
      # - "tme#"
      - "Notes"

