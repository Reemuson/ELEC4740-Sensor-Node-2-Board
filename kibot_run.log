# KiBot Filter for renaming Manufacturer Part Number field

kibot:
  version: 1

filters:
  - name: 'field_rename'
    comment: 'Rename fields'
    type: field_rename
    rename:
      - field: 'MPN'
        name: manf#
      - field: 'Manufacturer'
        name: manf

